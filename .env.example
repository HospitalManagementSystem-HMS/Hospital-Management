# Copy to .env (optional) and override defaults in docker-compose.yml
JWT_SECRET=change_this_in_production
INTERNAL_API_KEY=change_this_in_production
TZ=Asia/Kolkata

# Optional seed overrides
SEED=true
SEED_ADMIN_EMAIL=admin@hospital.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_DOCTOR_EMAIL=doctor@hospital.local
SEED_DOCTOR_PASSWORD=Doctor@12345
SEED_DOCTOR_NAME=Dr. Aisha Sharma
SEED_DOCTOR_SPECIALIZATION=General Physician
SEED_PATIENT_EMAIL=patient@hospital.local
SEED_PATIENT_PASSWORD=Patient@12345
SEED_PATIENT_NAME=Rahul Verma

# Medicine reminder wall-clock timezone (IANA) for 08:30 / 12:30 / 19:30 cron triggers
MED_REMINDER_TZ=UTC
FOLLOW_UP_POLL_SECONDS=60
